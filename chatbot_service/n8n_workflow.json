        "functionCode": "// Procesar datos del webhook\nconst body = $input.first().json.body;\n\nreturn {\n  json: {\n    message: body.message || '',\n    session_id: body.session_id || 'default',\n    timestamp: body.timestamp || new Date().toISOString(),\n    user_info: body.user_info || {}\n  }\n};"
      },
